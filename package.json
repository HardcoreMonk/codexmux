{
  "name": "codexmux",
  "version": "0.4.1",
  "description": "Manage multiple Codex sessions from your browser",
  "license": "MIT",
  "author": "HardcoreMonk",
  "repository": {
    "type": "git",
    "url": "https://github.com/HardcoreMonk/codexmux.git"
  },
  "homepage": "https://github.com/HardcoreMonk/codexmux",
  "bugs": {
    "url": "https://github.com/HardcoreMonk/codexmux/issues"
  },
  "keywords": [
    "codex",
    "openai",
    "terminal",
    "multiplexer",
    "tmux",
    "codex-cli"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.32.1",
  "main": "dist-electron/main.js",
  "bin": {
    "codexmux": "./bin/codexmux.js",
    "cmux": "./bin/codexmux.js"
  },
  "files": [
    "bin/",
    "dist/",
    ".next/standalone/",
    "src/config/tmux.conf"
  ],
  "scripts": {
    "dev": "tsx watch server.ts",
    "build": "next build && node scripts/post-build.js && tsup && node scripts/write-build-info.mjs",
    "build:landing": "eleventy",
    "dev:landing": "eleventy --serve",
    "build:server": "tsup",
    "verify:runtime-native": "node scripts/verify-runtime-native-bindings.mjs",
    "build:electron:main": "tsup --config electron/tsup.config.ts",
    "build:electron": "next build && node scripts/post-build.js --electron && tsup && tsup --config electron/tsup.config.ts && node scripts/write-build-info.mjs",
    "dev:electron": "node scripts/dev-electron.mjs",
    "dev:electron:attach": "ELECTRON_DEV_URL=http://localhost:8122 electron .",
    "pack:electron": "next build && node scripts/post-build.js --electron && tsup && tsup --config electron/tsup.config.ts && node scripts/write-build-info.mjs && electron-builder --mac",
    "pack:electron:dev": "next build && node scripts/post-build.js --electron && tsup && tsup --config electron/tsup.config.ts && node scripts/write-build-info.mjs && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac -c.mac.identity=null -c.mac.notarize=false",
    "android:sync": "cap sync android",
    "android:open": "cap open android",
    "android:run": "cap run android",
    "android:build": "cap sync android && cd android && ./gradlew assembleDebug",
    "android:build:debug": "cap sync android && cd android && ./gradlew assembleDebug",
    "android:build:release": "cap sync android && cd android && ./gradlew assembleRelease",
    "android:bundle:release": "cap sync android && cd android && ./gradlew bundleRelease",
    "android:install": "cap sync android && cd android && ./gradlew installDebug",
    "android:test:unit": "cd android && ./gradlew testDebugUnitTest",
    "android:clean": "cd android && ./gradlew clean",
    "android:keystore": "node scripts/android-keystore.mjs",
    "smoke:android:install": "node scripts/smoke-android-debug-install.mjs",
    "smoke:android:release-aab": "node scripts/verify-android-release-aab.mjs",
    "smoke:android:foreground": "node scripts/smoke-android-foreground-reconnect.mjs",
    "smoke:android:recovery": "node scripts/smoke-android-launcher-recovery.mjs",
    "smoke:android:runtime-v2": "node scripts/smoke-android-runtime-v2-foreground.mjs",
    "smoke:electron:attach": "node scripts/smoke-electron-attach.mjs",
    "smoke:electron:runtime-v2": "node scripts/smoke-electron-runtime-v2.mjs",
    "smoke:permission": "node scripts/smoke-permission-prompt.mjs",
    "smoke:pwa": "node scripts/smoke-pwa-readiness.mjs",
    "smoke:browser-reconnect": "node scripts/smoke-browser-reconnect-dom.mjs",
    "smoke:runtime-v2": "node scripts/smoke-runtime-v2-isolated.mjs",
    "smoke:runtime-v2:target": "node scripts/smoke-runtime-v2.mjs",
    "smoke:runtime-v2:phase2": "node scripts/smoke-runtime-v2-phase2-gate.mjs",
    "runtime-v2:storage-dry-run": "tsx scripts/runtime-v2-storage-dry-run.ts",
    "smoke:runtime-v2:storage-dry-run": "tsx scripts/smoke-runtime-v2-storage-dry-run.ts",
    "runtime-v2:storage-backup": "tsx scripts/runtime-v2-storage-backup.ts",
    "smoke:runtime-v2:storage-backup": "tsx scripts/smoke-runtime-v2-storage-backup.ts",
    "runtime-v2:storage-import": "tsx scripts/runtime-v2-storage-import.ts",
    "smoke:runtime-v2:storage-import": "tsx scripts/smoke-runtime-v2-storage-import.ts",
    "smoke:runtime-v2:storage-write": "tsx scripts/smoke-runtime-v2-storage-write.ts",
    "smoke:runtime-v2:storage-default-read": "tsx scripts/smoke-runtime-v2-storage-default-read.ts",
    "smoke:runtime-v2:storage-shadow": "tsx scripts/smoke-runtime-v2-storage-shadow.ts",
    "smoke:runtime-v2:timeline-shadow": "tsx scripts/smoke-runtime-v2-timeline-shadow.ts",
    "smoke:runtime-v2:status-shadow": "tsx scripts/smoke-runtime-v2-status-shadow.ts",
    "deploy:local": "node scripts/deploy-local.mjs",
    "release:patch": "node scripts/release.mjs patch",
    "release:minor": "node scripts/release.mjs minor",
    "release:major": "node scripts/release.mjs major",
    "start": "NODE_ENV=production tsx server.ts",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "rm -rf .next dist dist-electron && next build && node scripts/post-build.js && tsup && node scripts/write-build-info.mjs",
    "postinstall": "chmod +x node_modules/.pnpm/node-pty@*/node_modules/node-pty/prebuilds/*/spawn-helper 2>/dev/null; exit 0"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@capacitor/android": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@git-diff-view/core": "^0.1.3",
    "@git-diff-view/file": "^0.1.3",
    "@git-diff-view/react": "^0.1.3",
    "@tailwindcss/typography": "^0.5.19",
    "@xterm/addon-clipboard": "^0.2.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dayjs": "^1.11.20",
    "diff": "^9.0.0",
    "electron-updater": "^6.8.3",
    "jose": "^6.2.2",
    "lucide-react": "^1.7.0",
    "motion": "^12.38.0",
    "nanoid": "^5.1.7",
    "next": "16.2.4",
    "next-intl": "^4.9.1",
    "next-themes": "^0.4.6",
    "node-pty": "1.2.0-beta.12",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "pino-roll": "^4.0.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-hotkeys-hook": "^5.2.4",
    "react-icons": "^5.6.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.10.0",
    "recharts": "^3.8.0",
    "rehype-highlight": "^7.0.2",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "update-notifier": "^7.3.1",
    "use-stick-to-bottom": "^1.1.3",
    "vaul": "^1.1.2",
    "web-push": "^3.6.7",
    "ws": "^8.20.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.5",
    "@capacitor/cli": "^8.3.1",
    "@electron/rebuild": "^4.0.3",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.12.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "@types/ws": "^8.18.1",
    "astral-regex": "^2.0.0",
    "chalk": "^5.6.2",
    "dmg-license": "1.0.11",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "shadcn": "^4.1.2",
    "tailwindcss": "^4",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "node-pty"
    ],
    "overrides": {
      "hono": ">=4.12.14",
      "@hono/node-server": ">=1.19.13",
      "lodash": ">=4.18.0",
      "@xmldom/xmldom": "^0.8.13",
      "picomatch@>=2.0.0 <3.0.0": ">=2.3.2",
      "picomatch@>=4.0.0 <5.0.0": ">=4.0.4"
    }
  },
  "optionalDependencies": {
    "better-sqlite3": "^12.9.0"
  }
}
